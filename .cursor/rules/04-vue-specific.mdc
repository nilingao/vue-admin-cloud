# Vue 3 开发规则和最佳实践

## Vue 组件规范

### 组件结构
```vue
<script lang="ts" setup>
// 1. 导入依赖
import { ref, computed, onMounted } from 'vue';
import type { ComponentProps } from './types';

// 2. 定义 props 和 emits
interface Props {
  title: string;
  visible?: boolean;
}

const props = withDefaults(defineProps<Props>(), {
  visible: false,
});

const emit = defineEmits<{
  close: [];
  confirm: [value: string];
}>();

// 3. 响应式数据
const loading = ref(false);
const formData = ref({});

// 4. 计算属性
const isDisabled = computed(() => loading.value || !formData.value.name);

// 5. 方法
const handleSubmit = async () => {
  // 处理逻辑
};

// 6. 生命周期
onMounted(() => {
  // 初始化逻辑
});
</script>

<template>
  <!-- 模板内容 -->
</template>

<style scoped>
/* 样式内容 */
</style>
```

### 组件命名规范
- 组件文件使用 PascalCase: `UserList.vue`
- 组件名使用 PascalCase: `UserList`
- 使用 `defineOptions` 显式定义组件名

```vue
<script lang="ts" setup>
defineOptions({ name: 'UserList' });
</script>
```

## Composition API 最佳实践

### 响应式数据
```typescript
// 使用 ref 定义基本类型
const count = ref(0);
const message = ref('');

// 使用 reactive 定义对象
const state = reactive({
  loading: false,
  data: [],
});

// 使用 computed 定义计算属性
const doubleCount = computed(() => count.value * 2);
```

### 生命周期钩子
```typescript
import { onMounted, onUnmounted, onBeforeUnmount } from 'vue';

onMounted(() => {
  // 组件挂载后执行
});

onBeforeUnmount(() => {
  // 组件卸载前执行
});

onUnmounted(() => {
  // 组件卸载后执行
});
```

### 自定义 Hooks
```typescript
// 创建可复用的逻辑
export function useCounter(initialValue = 0) {
  const count = ref(initialValue);
  
  const increment = () => count.value++;
  const decrement = () => count.value--;
  
  return {
    count: readonly(count),
    increment,
    decrement,
  };
}
```

## 路由和导航

### 路由定义
```typescript
// 在 router/index.ts 中定义路由
const routes: RouteRecordRaw[] = [
  {
    path: '/user',
    name: 'User',
    component: () => import('@/views/user/index.vue'),
    meta: {
      title: '用户管理',
      requiresAuth: true,
    },
  },
];
```

### 路由导航
```typescript
import { useRouter, useRoute } from 'vue-router';

const router = useRouter();
const route = useRoute();

// 编程式导航
router.push('/user');
router.push({ name: 'User', params: { id: '123' } });

// 获取路由参数
const userId = route.params.id;
```

## 状态管理 (Pinia)

### Store 定义
```typescript
// stores/user.ts
import { defineStore } from 'pinia';

export const useUserStore = defineStore('user', () => {
  const userInfo = ref(null);
  const isLoggedIn = computed(() => !!userInfo.value);
  
  const login = async (credentials: LoginCredentials) => {
    // 登录逻辑
  };
  
  const logout = () => {
    userInfo.value = null;
  };
  
  return {
    userInfo: readonly(userInfo),
    isLoggedIn,
    login,
    logout,
  };
});
```

### Store 使用
```vue
<script lang="ts" setup>
import { useUserStore } from '@/stores/user';

const userStore = useUserStore();

// 使用 store 中的数据和方法
const handleLogin = () => {
  userStore.login(loginForm.value);
};
</script>
```

## 表单处理

### 表单验证
```vue
<script lang="ts" setup>
import { ref } from 'vue';
import { Form, Input, Button } from 'ant-design-vue';

const formRef = ref();
const formData = ref({
  username: '',
  email: '',
});

const rules = {
  username: [
    { required: true, message: '请输入用户名' },
    { min: 3, max: 20, message: '用户名长度在 3 到 20 个字符' },
  ],
  email: [
    { required: true, message: '请输入邮箱' },
    { type: 'email', message: '请输入有效的邮箱地址' },
  ],
};

const handleSubmit = async () => {
  try {
    await formRef.value.validate();
    // 提交表单
  } catch (error) {
    console.error('表单验证失败:', error);
  }
};
</script>
```

## 异步数据处理

### API 调用
```typescript
import { ref } from 'vue';
import { getUserList } from '@/api/user';

const loading = ref(false);
const userList = ref([]);
const error = ref(null);

const fetchUsers = async () => {
  loading.value = true;
  error.value = null;
  
  try {
    const response = await getUserList();
    userList.value = response.data;
  } catch (err) {
    error.value = err.message;
  } finally {
    loading.value = false;
  }
};
```

### 错误处理
```typescript
import { message } from 'ant-design-vue';

const handleError = (error: Error) => {
  console.error('操作失败:', error);
  message.error(error.message || '操作失败，请重试');
};
```

## 性能优化

### 组件懒加载
```typescript
// 路由懒加载
const UserList = () => import('@/views/user/UserList.vue');

// 组件懒加载
const LazyComponent = defineAsyncComponent(() => import('./LazyComponent.vue'));
```

### 计算属性缓存
```typescript
// 使用 computed 而不是在模板中直接计算
const filteredList = computed(() => {
  return list.value.filter(item => item.active);
});
```

### 事件处理优化
```vue
<template>
  <!-- 使用 .prevent 修饰符 -->
  <form @submit.prevent="handleSubmit">
    <!-- 使用 .stop 修饰符 -->
    <button @click.stop="handleClick">点击</button>
  </form>
</template>
```

