# 测试和部署规则

## 测试配置

### 测试框架
- **单元测试**: Vitest
- **E2E 测试**: Playwright
- **测试配置**: [vitest.config.ts](mdc:vitest.config.ts)

### 测试命令
```bash
# 运行单元测试
pnpm test:unit

# 运行 E2E 测试
pnpm test:e2e

# 测试覆盖率
pnpm test:coverage
```

## 单元测试规范

### 组件测试
```typescript
import { mount } from '@vue/test-utils';
import { describe, it, expect } from 'vitest';
import UserList from '@/components/UserList.vue';

describe('UserList', () => {
  it('renders user list correctly', () => {
    const wrapper = mount(UserList, {
      props: {
        users: [
          { id: '1', name: 'John Doe', email: 'john@example.com' },
          { id: '2', name: 'Jane Smith', email: 'jane@example.com' },
        ],
      },
    });

    expect(wrapper.find('.user-list').exists()).toBe(true);
    expect(wrapper.findAll('.user-item')).toHaveLength(2);
  });

  it('emits select event when user is clicked', async () => {
    const wrapper = mount(UserList, {
      props: {
        users: [{ id: '1', name: 'John Doe', email: 'john@example.com' }],
      },
    });

    await wrapper.find('.user-item').trigger('click');
    expect(wrapper.emitted('select')).toBeTruthy();
    expect(wrapper.emitted('select')?.[0]).toEqual(['1']);
  });
});
```

### API 测试
```typescript
import { describe, it, expect, vi } from 'vitest';
import { getUserList, createUser } from '@/api/user';

// Mock API 请求
vi.mock('@/api/request', () => ({
  requestClient: {
    get: vi.fn(),
    post: vi.fn(),
  },
}));

describe('User API', () => {
  it('fetches user list successfully', async () => {
    const mockUsers = [
      { id: '1', name: 'John Doe', email: 'john@example.com' },
    ];
    
    vi.mocked(requestClient.get).mockResolvedValue({ data: mockUsers });
    
    const result = await getUserList({ page: 1, size: 10 });
    expect(result).toEqual(mockUsers);
    expect(requestClient.get).toHaveBeenCalledWith('/api/users', {
      params: { page: 1, size: 10 },
    });
  });
});
```

### Store 测试
```typescript
import { describe, it, expect, beforeEach } from 'vitest';
import { setActivePinia, createPinia } from 'pinia';
import { useUserStore } from '@/stores/user';

describe('User Store', () => {
  beforeEach(() => {
    setActivePinia(createPinia());
  });

  it('initializes with empty user info', () => {
    const store = useUserStore();
    expect(store.userInfo).toBeNull();
    expect(store.isLoggedIn).toBe(false);
  });

  it('sets user info correctly', () => {
    const store = useUserStore();
    const userInfo = { id: '1', name: 'John Doe' };
    
    store.setUserInfo(userInfo);
    expect(store.userInfo).toEqual(userInfo);
    expect(store.isLoggedIn).toBe(true);
  });
});
```

## E2E 测试规范

### 页面测试
```typescript
import { test, expect } from '@playwright/test';

test.describe('User Management', () => {
  test.beforeEach(async ({ page }) => {
    // 登录
    await page.goto('/login');
    await page.fill('[data-testid="username"]', 'admin');
    await page.fill('[data-testid="password"]', 'password');
    await page.click('[data-testid="login-button"]');
    await page.waitForURL('/dashboard');
  });

  test('should display user list', async ({ page }) => {
    await page.goto('/system/user');
    await expect(page.locator('[data-testid="user-list"]')).toBeVisible();
    await expect(page.locator('[data-testid="add-user-button"]')).toBeVisible();
  });

  test('should create new user', async ({ page }) => {
    await page.goto('/system/user');
    await page.click('[data-testid="add-user-button"]');
    
    await page.fill('[data-testid="username"]', 'newuser');
    await page.fill('[data-testid="email"]', 'newuser@example.com');
    await page.click('[data-testid="submit-button"]');
    
    await expect(page.locator('.ant-message-success')).toBeVisible();
  });
});
```

## 测试最佳实践

### 测试命名规范
- 测试文件以 `.test.ts` 或 `.spec.ts` 结尾
- 测试描述使用中文，清晰表达测试意图
- 使用 `describe` 分组相关测试
- 使用 `it` 或 `test` 描述单个测试用例

### 测试数据管理
```typescript
// 测试数据工厂
export const createMockUser = (overrides: Partial<UserModel> = {}): UserModel => ({
  id: '1',
  username: 'testuser',
  realName: 'Test User',
  email: 'test@example.com',
  phone: '13800138000',
  status: 1,
  createTime: '2024-01-01 00:00:00',
  ...overrides,
});

// 测试工具函数
export const waitForElement = async (selector: string, timeout = 5000) => {
  return new Promise((resolve, reject) => {
    const element = document.querySelector(selector);
    if (element) {
      resolve(element);
    } else {
      setTimeout(() => reject(new Error('Element not found')), timeout);
    }
  });
};
```

### Mock 策略
